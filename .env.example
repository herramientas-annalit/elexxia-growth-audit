# ─── Base de datos MySQL ──────────────────────────────────────────────────────
# TiDB Serverless (gratis, 25GB): https://tidbcloud.com
# PlanetScale alternativa: https://planetscale.com
DATABASE_URL=mysql://usuario:password@host/elexxia_audit?ssl={"rejectUnauthorized":true}

# ─── Seguridad ────────────────────────────────────────────────────────────────
JWT_SECRET=cambia-esto-por-una-clave-aleatoria-de-32-caracteres

# ─── LLM (OpenAI) ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── Dashboard Admin ─────────────────────────────────────────────────────────
ADMIN_PASSWORD=tu-contrasena-segura
ADMIN_EMAIL=admin@elexxia.es

# ─── Notificaciones Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=tu-bot-token
TELEGRAM_OWNER_CHAT_ID=tu-chat-id

# ─── Email al cliente (Resend — opcional) ────────────────────────────────────
# Crear cuenta gratis en https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=Elexxia <diagnostico@elexxia.com>

# ─── Producción ──────────────────────────────────────────────────────────────
NODE_ENV=production
